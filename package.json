{
  "name": "libif",
  "private": true,
  "version": "0.1.0",
  "description": "LIBIF",
  "workspaces": [
    "packages/shared",
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "openapi:generate": "npm run openapi:generate -w apps/api && npm run api:types -w apps/web",
    "test:e2e": "npm run test:e2e -w apps/api",
    "db:migrate": "npm run db:migrate -w apps/api",
    "db:seed": "npm run db:seed -w apps/api"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "@hono/node-server": "^1.19.13"
  }
}
