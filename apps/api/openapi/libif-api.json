          "totalPages",
          "percentage",
          "lastReadAt"
        ]
      },
      "ReaderLibraryItemDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "cm123456789"
          },
          "title": {
            "type": "string",
            "example": "Intro to Algorithms"
          },
          "subtitle": {
            "type": "string",
            "example": "2nd Edition"
          },
          "authors": {
            "example": [
              "Thomas H. Cormen"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "publisher": {
            "type": "string",
            "example": "MIT Press"
          },
          "publishedYear": {
            "type": "number",
            "example": 2009
          },
          "status": {
            "type": "string",
            "example": "PUBLISHED"
          },
          "bookmarked": {
            "type": "boolean",
            "example": true
          },
          "progress": {
            "$ref": "#/components/schemas/ReadingProgressStateDto"
          },
