          "totalPages": {
            "type": "number",
            "example": 100
          },
          "percentage": {
            "type": "number",
            "example": 5
          },
          "lastReadAt": {
            "type": "string",
            "example": "2026-07-21T10:00:00.000Z"
          }
        },
        "required": [
