      "ProtectedDocumentUrlDto": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "example": "access_token_abc123"
          },
          "expiresAt": {
            "type": "string",
            "example": "2026-07-21T11:45:00.000Z"
          },
          "url": {
            "type": "string",
            "example": "/api/access/stream?token=access_token_abc123"
          }
        },
        "required": [
