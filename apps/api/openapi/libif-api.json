                  "$ref": "#/components/schemas/AuthMessageDto"
                }
              }
            }
          }
        },
        "summary": "Revoke the current session and clear the session cookie.",
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/auth/session": {
      "get": {
        "operationId": "getSession",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionDto"
                }
              }
            }
          }
        },
        "summary": "Return the current session boundary state.",
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/auth/password-reset-requests": {
      "post": {
        "operationId": "requestPasswordReset",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PasswordResetRequestDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthMessageDto"
                }
              }
            }
          }
        },
        "summary": "Request a password reset link if an account exists.",
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/auth/password-resets": {
      "post": {
        "operationId": "resetPassword",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PasswordResetDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthMessageDto"
                }
              }
            }
          },
          "400": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthErrorDto"
                }
              }
            }
          }
        },
        "summary": "Reset a password with a valid reset token.",
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/admin/dashboard/librarian": {
      "get": {
        "operationId": "getLibrarianDashboardSummary",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LibrarianDashboardSummaryDto"
                }
              }
            }
          },
          "403": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthErrorDto"
                }
              }
            }
          }
        },
        "summary": "Return librarian dashboard summary counts.",
        "tags": [
          "Admin Dashboard"
        ]
      }
    },
    "/api/admin/books/intake": {
      "post": {
        "operationId": "createIntake",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "file",
                  "metadata"
                ],
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  },
                  "metadata": {
                    "type": "string",
                    "description": "JSON string matching CreateBookIntakeDto."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateBookIntakeResponseDto"
                }
              }
            }
          },
          "403": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthErrorDto"
                }
              }
            }
          }
        },
        "summary": "Create a digital book intake and queue processing.",
        "tags": [
          "Admin Books"
        ]
      }
    },
    "/api/admin/books": {
      "get": {
        "operationId": "listAdminBooks",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/BookListItemResponseDto"
                  }
                }
              }
            }
          },
          "403": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthErrorDto"
                }
              }
            }
          }
        },
        "summary": "List digital book intake records for staff.",
        "tags": [
          "Admin Books"
        ]
      }
    },
    "/api/categories": {
      "get": {
        "operationId": "listCategories",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CategoryResponseDto"
                  }
                }
              }
            }
          }
        },
        "summary": "List public category options.",
        "tags": [
          "Catalog"
        ]
      }
    },
    "/api/catalog/books": {
      "get": {
        "operationId": "listPublicBooks",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/BookListItemResponseDto"
                  }
                }
              }
            }
          }
        },
        "summary": "List published public catalogue books.",
        "tags": [
          "Catalog"
        ]
      }
    },
    "/api/isbn/{isbn}": {
      "get": {
        "operationId": "lookup",
        "parameters": [
          {
            "name": "isbn",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IsbnLookupResponseDto"
                }
              }
            }
          }
        },
        "summary": "Look up metadata for an ISBN.",
        "tags": [
          "ISBN"
        ]
      }
    },
    "/api/health": {
      "get": {
        "operationId": "health",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponseDto"
                }
              }
            }
          }
        },
        "tags": [
          "Health"
        ]
      }
    }
  },
  "info": {
    "title": "LIBIF API",
    "description": "OpenAPI contract for LIBIF web and API integration.",
    "version": "0.1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "RegisterRequestDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "reader@example.edu"
          },
          "password": {
            "type": "string",
            "minLength": 12,
            "example": "correct horse battery staple"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "SessionUserDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "dev-librarian"
          },
          "email": {
            "type": "string",
            "example": "librarian@libif.local"
          },
          "role": {
            "type": "string",
            "enum": [
              "ADMIN",
              "LIBRARIAN",
              "READER"
            ]
          },
          "permissions": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "catalogue:read",
                "reader:library:read",
                "admin:books:read",
                "admin:books:write",
                "admin:taxonomy:manage",
                "admin:users:manage"
              ]
            }
          }
        },
        "required": [
          "id",
          "email",
          "role",
          "permissions"
        ]
      },
      "SessionDto": {
        "type": "object",
        "properties": {
          "authenticated": {
            "type": "boolean",
            "example": true
          },
          "user": {
            "$ref": "#/components/schemas/SessionUserDto"
          },
          "permissions": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "catalogue:read",
                "reader:library:read",
                "admin:books:read",
                "admin:books:write",
                "admin:taxonomy:manage",
                "admin:users:manage"
              ]
            }
          },
          "strategy": {
            "type": "string",
            "enum": [
              "persistent-cookie",
              "development-header"
            ]
          }
        },
        "required": [
          "authenticated",
          "permissions",
          "strategy"
        ]
      },
      "AuthErrorDto": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "example": "AUTHENTICATION_REQUIRED"
          },
          "message": {
            "type": "string",
            "example": "Authentication is required."
          },
          "fieldErrors": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "example": {}
          },
          "traceId": {
            "type": "string",
            "example": "request-trace-id"
          },
          "status": {
            "type": "number",
            "example": 403
          }
        },
        "required": [
          "code",
          "message",
          "fieldErrors",
          "traceId",
          "status"
        ]
      },
      "SignInRequestDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "reader@example.edu"
          },
          "password": {
            "type": "string",
            "example": "correct horse battery staple"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "AuthMessageDto": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "If an account exists for that email, a reset link has been sent."
          }
        },
        "required": [
          "message"
        ]
      },
      "PasswordResetRequestDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "reader@example.edu"
          }
        },
        "required": [
          "email"
        ]
      },
      "PasswordResetDto": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "example": "reset-token-from-email"
          },
          "password": {
            "type": "string",
            "minLength": 12,
            "example": "new correct horse battery staple"
          }
        },
        "required": [
          "token",
          "password"
        ]
      },
      "BookStatusCountsDto": {
        "type": "object",
        "properties": {
          "total": {
            "type": "number"
          },
          "draft": {
            "type": "number"
          },
          "pendingProcessing": {
            "type": "number"
          },
          "processing": {
            "type": "number"
          },
          "pendingApproval": {
            "type": "number"
          },
          "published": {
            "type": "number"
          },
          "rejected": {
            "type": "number"
          }
        },
        "required": [
          "total",
          "draft",
          "pendingProcessing",
          "processing",
          "pendingApproval",
          "published",
          "rejected"
        ]
      },
      "ProcessingJobStatusCountsDto": {
        "type": "object",
        "properties": {
          "queued": {
            "type": "number"
          },
          "running": {
            "type": "number"
          },
          "succeeded": {
            "type": "number"
          },
          "failed": {
            "type": "number"
          }
        },
        "required": [
          "queued",
          "running",
          "succeeded",
          "failed"
        ]
      },
      "TaxonomyCountsDto": {
        "type": "object",
        "properties": {
          "categories": {
            "type": "number"
          },
          "tags": {
            "type": "number"
          }
        },
        "required": [
          "categories",
          "tags"
        ]
      },
      "UserRoleCountsDto": {
        "type": "object",
        "properties": {
          "admins": {
            "type": "number"
          },
          "librarians": {
            "type": "number"
          },
          "readers": {
            "type": "number"
          },
          "total": {
            "type": "number"
          }
        },
        "required": [
          "admins",
          "librarians",
          "readers",
          "total"
        ]
      },
      "RecentBookSummaryDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "DRAFT",
              "PENDING_PROCESSING",
              "PROCESSING",
              "PENDING_APPROVAL",
              "PUBLISHED",
              "REJECTED"
            ]
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "title",
          "status",
          "createdAt"
        ]
      },
      "LibrarianDashboardSummaryDto": {
        "type": "object",
        "properties": {
          "generatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "books": {
            "$ref": "#/components/schemas/BookStatusCountsDto"
          },
          "processingJobs": {
            "$ref": "#/components/schemas/ProcessingJobStatusCountsDto"
          },
          "taxonomy": {
            "$ref": "#/components/schemas/TaxonomyCountsDto"
          },
          "users": {
            "$ref": "#/components/schemas/UserRoleCountsDto"
          },
          "recentBooks": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RecentBookSummaryDto"
            }
          }
        },
        "required": [
          "generatedAt",
          "books",
          "processingJobs",
          "taxonomy",
          "users",
          "recentBooks"
        ]
      },
      "IntakeBookSummaryDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "DRAFT",
              "PENDING_PROCESSING",
              "PROCESSING",
              "PENDING_APPROVAL",
              "PUBLISHED",
              "REJECTED"
            ]
          }
        },
        "required": [
          "id",
          "title",
          "status"
        ]
      },
      "IntakeFileSummaryDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "originalFilename": {
            "type": "string"
          },
          "sizeBytes": {
            "type": "string",
            "example": "123456"
          }
        },
        "required": [
          "id",
          "originalFilename",
          "sizeBytes"
        ]
      },
      "IntakeProcessingJobSummaryDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "QUEUED",
              "RUNNING",
              "SUCCEEDED",
              "FAILED"
            ]
          }
        },
        "required": [
          "id",
          "status"
        ]
      },
      "CreateBookIntakeResponseDto": {
        "type": "object",
        "properties": {
          "book": {
            "$ref": "#/components/schemas/IntakeBookSummaryDto"
          },
          "file": {
            "$ref": "#/components/schemas/IntakeFileSummaryDto"
          },
          "processingJob": {
            "$ref": "#/components/schemas/IntakeProcessingJobSummaryDto"
          }
        },
        "required": [
          "book",
          "file",
          "processingJob"
        ]
      },
      "CategoryResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "parentId": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "id",
          "name",
          "slug"
        ]
      },
      "TagResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "name",
          "slug"
        ]
      },
      "AuthorResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "name"
        ]
      },
      "BookFileSummaryDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "originalFilename": {
            "type": "string"
          },
          "sizeBytes": {
            "type": "string",
            "example": "123456"
          }
        },
        "required": [
          "id",
          "originalFilename",
          "sizeBytes"
        ]
      },
      "BookListItemResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "isbn": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "type": "string",
            "enum": [
              "DRAFT",
              "PENDING_PROCESSING",
              "PROCESSING",
              "PENDING_APPROVAL",
              "PUBLISHED",
              "REJECTED"
            ]
          },
          "category": {
            "nullable": true,
            "type": "object",
            "allOf": [
              {
                "$ref": "#/components/schemas/CategoryResponseDto"
              }
            ]
          },
          "tags": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TagResponseDto"
            }
          },
          "authors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AuthorResponseDto"
            }
          },
          "file": {
            "nullable": true,
            "type": "object",
            "allOf": [
              {
                "$ref": "#/components/schemas/BookFileSummaryDto"
              }
            ]
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "title",
          "status",
          "tags",
          "authors",
          "createdAt"
        ]
      },
      "IsbnMetadataDto": {
        "type": "object",
        "properties": {
          "isbn": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "authors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "publisher": {
            "type": "string"
          },
          "publishedYear": {
            "type": "number"
          },
          "description": {
            "type": "string"
          },
          "language": {
            "type": "string"
          }
        }
      },
      "IsbnLookupResponseDto": {
        "type": "object",
        "properties": {
          "found": {
            "type": "boolean"
          },
          "metadata": {
            "$ref": "#/components/schemas/IsbnMetadataDto"
          },
          "message": {
            "type": "string"
          }
        },
        "required": [
          "found"
        ]
      },
      "HealthResponseDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "ok"
          },
          "service": {
            "type": "string",
            "example": "libif-api"
          }
        },
        "required": [
          "status",
          "service"
        ]
      }
    }
  }
}
