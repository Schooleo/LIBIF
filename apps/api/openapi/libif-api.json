  "info": {
    "title": "LIBIF API",
    "description": "OpenAPI contract for LIBIF web and API integration.",
    "version": "0.1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "RegisterRequestDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "reader@example.edu"
          },
          "password": {
            "type": "string",
            "minLength": 12,
            "example": "correct horse battery staple"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "SessionUserDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "dev-librarian"
          },
          "email": {
            "type": "string",
            "example": "librarian@libif.local"
          },
          "role": {
            "type": "string",
            "enum": [
              "ADMIN",
              "LIBRARIAN",
              "READER"
            ]
          },
          "permissions": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "catalogue:read",
                "reader:library:read",
                "admin:books:read",
                "admin:books:write",
                "admin:taxonomy:manage",
                "admin:users:manage"
              ]
            }
          }
        },
        "required": [
          "id",
          "email",
          "role",
          "permissions"
        ]
      },
      "SessionDto": {
        "type": "object",
        "properties": {
          "authenticated": {
            "type": "boolean",
            "example": true
          },
          "user": {
            "$ref": "#/components/schemas/SessionUserDto"
          },
          "permissions": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "catalogue:read",
                "reader:library:read",
                "admin:books:read",
                "admin:books:write",
                "admin:taxonomy:manage",
                "admin:users:manage"
              ]
            }
          },
          "strategy": {
            "type": "string",
            "enum": [
              "persistent-cookie",
              "development-header"
            ]
          }
        },
        "required": [
          "authenticated",
          "permissions",
          "strategy"
        ]
      },
      "AuthErrorDto": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "example": "AUTHENTICATION_REQUIRED"
          },
          "message": {
            "type": "string",
            "example": "Authentication is required."
          },
          "fieldErrors": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "example": {}
          },
          "traceId": {
            "type": "string",
            "example": "request-trace-id"
          },
          "status": {
            "type": "number",
            "example": 403
          }
        },
        "required": [
          "code",
          "message",
          "fieldErrors",
          "traceId",
          "status"
        ]
      },
      "SignInRequestDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "reader@example.edu"
          },
          "password": {
            "type": "string",
            "example": "correct horse battery staple"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "AuthMessageDto": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "If an account exists for that email, a reset link has been sent."
          }
        },
        "required": [
          "message"
        ]
      },
      "PasswordResetRequestDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "reader@example.edu"
          }
        },
        "required": [
          "email"
        ]
      },
      "PasswordResetDto": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "example": "reset-token-from-email"
          },
          "password": {
            "type": "string",
            "minLength": 12,
            "example": "new correct horse battery staple"
          }
        },
        "required": [
          "token",
          "password"
        ]
      },
      "IntakeBookSummaryDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "DRAFT",
              "PENDING_PROCESSING",
              "PROCESSING",
              "PENDING_APPROVAL",
              "PUBLISHED",
              "REJECTED"
            ]
          }
        },
        "required": [
          "id",
          "title",
          "status"
        ]
      },
      "IntakeFileSummaryDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "originalFilename": {
            "type": "string"
          },
          "sizeBytes": {
            "type": "string",
            "example": "123456"
          }
        },
        "required": [
          "id",
          "originalFilename",
          "sizeBytes"
        ]
      },
      "IntakeProcessingJobSummaryDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "QUEUED",
              "RUNNING",
              "SUCCEEDED",
              "FAILED"
            ]
          }
        },
        "required": [
          "id",
          "status"
        ]
      },
      "CreateBookIntakeResponseDto": {
        "type": "object",
        "properties": {
          "book": {
            "$ref": "#/components/schemas/IntakeBookSummaryDto"
          },
          "file": {
            "$ref": "#/components/schemas/IntakeFileSummaryDto"
          },
          "processingJob": {
            "$ref": "#/components/schemas/IntakeProcessingJobSummaryDto"
          }
        },
        "required": [
          "book",
          "file",
          "processingJob"
        ]
      },
      "CategoryResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "parentId": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "id",
          "name",
          "slug"
        ]
      },
      "TagResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "name",
          "slug"
        ]
      },
      "AuthorResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "name"
        ]
      },
      "BookFileSummaryDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "originalFilename": {
            "type": "string"
          },
          "sizeBytes": {
            "type": "string",
            "example": "123456"
          }
        },
        "required": [
          "id",
          "originalFilename",
          "sizeBytes"
        ]
      },
      "BookListItemResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "isbn": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "type": "string",
            "enum": [
              "DRAFT",
              "PENDING_PROCESSING",
              "PROCESSING",
              "PENDING_APPROVAL",
              "PUBLISHED",
              "REJECTED"
            ]
          },
          "category": {
            "nullable": true,
            "type": "object",
            "allOf": [
              {
                "$ref": "#/components/schemas/CategoryResponseDto"
              }
            ]
          },
          "tags": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TagResponseDto"
            }
          },
          "authors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AuthorResponseDto"
            }
          },
          "file": {
            "nullable": true,
            "type": "object",
            "allOf": [
              {
                "$ref": "#/components/schemas/BookFileSummaryDto"
              }
            ]
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "title",
          "status",
          "tags",
          "authors",
          "createdAt"
        ]
      },
      "IsbnMetadataDto": {
        "type": "object",
