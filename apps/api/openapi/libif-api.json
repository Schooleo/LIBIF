  "info": {
    "title": "LIBIF API",
    "description": "OpenAPI contract for LIBIF web and API integration.",
    "version": "0.1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "RegisterRequestDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "reader@example.edu"
          },
          "password": {
            "type": "string",
            "minLength": 12,
            "example": "correct horse battery staple"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "SessionUserDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "dev-librarian"
          },
          "email": {
            "type": "string",
            "example": "librarian@libif.local"
          },
          "role": {
            "type": "string",
            "enum": [
              "ADMIN",
              "LIBRARIAN",
              "READER"
            ]
          },
          "permissions": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "catalogue:read",
                "reader:library:read",
                "admin:books:read",
                "admin:books:write",
                "admin:taxonomy:manage",
                "admin:users:manage"
              ]
            }
          }
        },
        "required": [
          "id",
          "email",
          "role",
          "permissions"
        ]
      },
      "SessionDto": {
        "type": "object",
        "properties": {
          "authenticated": {
            "type": "boolean",
            "example": true
          },
          "user": {
            "$ref": "#/components/schemas/SessionUserDto"
          },
