{
  "name": "@libif/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "npm --prefix ../../packages/shared run build && npm run prisma:generate",
    "dev": "nest start --watch",
    "prebuild": "npm --prefix ../../packages/shared run build && npm run prisma:generate",
    "build": "nest build",
    "start": "node dist/src/main.js",
    "openapi:generate": "npm run build && node dist/src/openapi.generate.js",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" \"prisma/**/*.ts\" \"prisma.config.ts\"",
    "pretest": "npm run prisma:generate",
    "test": "jest --runInBand",
    "pretest:e2e": "npm run prisma:generate",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev && npm run prisma:generate",
    "db:seed": "npm run prisma:generate && dotenv -e ../../.env -- tsx prisma/seed.ts",
    "prisma:generate": "dotenv -e ../../.env -- prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1089.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/swagger": "^11.4.6",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bullmq": "^5.80.6",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.2",
    "multer": "^2.2.0",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "slugify": "^1.6.9"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.24",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.28",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.2.0",
    "@types/node": "^24.13.3",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.7.0",
    "jest": "^30.4.2",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0"
  }
}
