COMPOSE_PROJECT_NAME=libif
DATABASE_URL="postgresql://library:library@localhost:5432/libif?schema=public"
REDIS_URL="redis://localhost:6379"
OCR_LANGUAGES="vie+eng"
OCR_COMMAND_TIMEOUT_MS=60000
OCR_MAX_PAGES=50
OCR_RENDER_DPI=200
# Optional. Defaults to the operating-system temp directory.
OCR_TEMP_ROOT=
# Legacy temp workspaces without an owning process ID are purged after one hour.
OCR_TEMP_STALE_AGE_MS=3600000
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="libif-pdfs"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
NEXT_PUBLIC_API_BASE_URL="http://localhost:3001"
LIBIF_WEB_BASE_URL="http://localhost:3000"
# Optional: set when web/API run on a shared parent domain in deployed environments.
LIBIF_SESSION_COOKIE_DOMAIN=
# Development auth fallback is disabled unless both API and web explicitly opt in.
LIBIF_ENABLE_DEV_AUTH="false"
NEXT_PUBLIC_LIBIF_ENABLE_DEV_AUTH="false"
NEXT_PUBLIC_LIBIF_DEV_ROLE="LIBRARIAN"
NEXT_PUBLIC_LIBIF_DEV_EMAIL="librarian@libif.local"
API_PORT=3001

# Optional debug tooling
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL="admin@libif.com"
PGADMIN_DEFAULT_PASSWORD="admin"
